model Recipe {
  id String @id @default(cuid())

  // Bilingual name
  nameEn String
  nameFr String?

  outputItemId   String
  outputItem     Item    @relation("RecipeOutput", fields: [outputItemId], references: [id])
  outputQuantity Decimal @db.Decimal(12, 3)

  laborCost    Decimal? @db.Decimal(12, 2)
  overheadCost Decimal? @db.Decimal(12, 2)

  // Versioning — recipes change without breaking historical batch costs
  version  Int     @default(1)
  isActive Boolean @default(true)
  notes    String?

  deletedAt DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  ingredients       RecipeIngredient[]
  productionBatches ProductionBatch[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([organizationId, isActive, deletedAt])
  @@index([outputItemId])
  @@map("recipes")
}

model RecipeIngredient {
  id       String @id @default(cuid())
  recipeId String
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  itemId   String
  item     Item    @relation("RecipeIngredient", fields: [itemId], references: [id])
  quantity Decimal @db.Decimal(12, 3)

  wastePercent Decimal? @db.Decimal(5, 2)
  notes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([recipeId])
  @@index([itemId])
  @@map("recipe_ingredients")
}

model ProductionBatch {
  id          String @id @default(cuid())
  batchNumber String // per-org unique

  recipeId String
  recipe   Recipe @relation(fields: [recipeId], references: [id])

  plannedQuantity Decimal @db.Decimal(12, 3)
  actualQuantity  Decimal @default(0) @db.Decimal(12, 3)

  status      ProductionBatchStatus @default(PLANNED)
  startedAt   DateTime              @default(now())
  completedAt DateTime?

  totalInputCost Decimal? @db.Decimal(14, 2)
  unitCost       Decimal? @db.Decimal(12, 2)

  notes String?

  deletedAt DateTime?

  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdById String?
  createdBy   User?   @relation("ProductionCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, batchNumber])
  @@index([recipeId])
  @@index([organizationId, status, startedAt])
  @@index([locationId])
  @@map("production_batches")
}

enum ProductionBatchStatus {
