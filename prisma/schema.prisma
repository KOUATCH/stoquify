  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  payrollPeriodId String
  payrollPeriod   PayrollPeriod @relation(fields: [payrollPeriodId], references: [id], onDelete: Restrict)

  originalRunId String?
  originalRun   PayrollRun?  @relation("PayrollRunCorrections", fields: [originalRunId], references: [id])
  correctiveRuns PayrollRun[] @relation("PayrollRunCorrections")

  runNumber String
  runType   PayrollRunType   @default(ORDINARY)
  status    PayrollRunStatus @default(DRAFT)
  version   Int              @default(1)

  countryCode                 String
  countryPackVersion          String
  countryPackSchemaVersion    String
  countryPackResolutionHash   String
  countryPackCapabilityStatus String
  ruleSetHash                 String
  calculationHash             String
  attendanceSnapshotHash      String

  grossAmount             Decimal @default(0) @db.Decimal(14, 2)
  employeeDeductionAmount Decimal @default(0) @db.Decimal(14, 2)
  employerChargeAmount    Decimal @default(0) @db.Decimal(14, 2)
  netPayableAmount        Decimal @default(0) @db.Decimal(14, 2)
  currency                String  @default("XAF")

  idempotencyKey String?
  documentHash   String?
  evidenceHash   String?

  ledgerPostingBatchId  String?
  postedBusinessEventId String?
  journalEntryId        String?
  accountingSourceLinkId String?

  preparedById String?
  reviewedById String?
  approvedById String?
  emittedById  String?
  postedById   String?
  approvedAt   DateTime?
  emittedAt    DateTime?
  postedAt     DateTime?
  archivedAt   DateTime?
  cancelledAt  DateTime?

  metadata  Json?
  deletedAt DateTime?

  lines            PayrollRunLine[]
  payslips         PayrollPayslip[]
  declarations     PayrollDeclaration[]
  paymentBatches   PayrollPaymentBatch[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, runNumber])
  @@unique([organizationId, idempotencyKey])
  @@index([organizationId, status, createdAt])
  @@index([organizationId, payrollPeriodId, runType])
  @@index([ledgerPostingBatchId])
  @@index([postedBusinessEventId])
  @@index([originalRunId])
  @@map("payroll_runs")
}

model PayrollRunLine {
  id String @id @default(cuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  payrollRunId String
  payrollRun   PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)

  employeeId String
  employee   PayrollEmployee @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  contractId String
  contract   PayrollContract @relation(fields: [contractId], references: [id], onDelete: Restrict)

  attendanceSnapshotId String?
  attendanceSnapshot   PayrollAttendanceSnapshot? @relation(fields: [attendanceSnapshotId], references: [id], onDelete: SetNull)

  grossAmount             Decimal @default(0) @db.Decimal(14, 2)
  taxableBaseAmount       Decimal @default(0) @db.Decimal(14, 2)
  socialBaseAmount        Decimal @default(0) @db.Decimal(14, 2)
  employeeDeductionAmount Decimal @default(0) @db.Decimal(14, 2)
  employerChargeAmount    Decimal @default(0) @db.Decimal(14, 2)
  netPayableAmount        Decimal @default(0) @db.Decimal(14, 2)
  currency                String  @default("XAF")

  calculationSnapshot Json
  ruleProvenance      Json
  anomalyFlags        Json?
  documentHash        String?
  metadata            Json?

  payslip PayrollPayslip?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([payrollRunId, employeeId])
  @@index([organizationId, employeeId])
  @@index([contractId])
  @@index([attendanceSnapshotId])
  @@map("payroll_run_lines")
}

model PayrollPayslip {
  id String @id @default(cuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  payrollRunId String
  payrollRun   PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Restrict)

  runLineId String @unique
  runLine   PayrollRunLine @relation(fields: [runLineId], references: [id], onDelete: Restrict)

  employeeId String
  employee   PayrollEmployee @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  payslipNumber String
  status        PayrollPayslipStatus @default(DRAFT)
  issuedAt      DateTime?
  voidedAt      DateTime?

  countryCode               String
  countryPackVersion        String
  countryPackSchemaVersion  String
  countryPackResolutionHash String
  ruleSetHash               String

  grossAmount             Decimal @default(0) @db.Decimal(14, 2)
  employeeDeductionAmount Decimal @default(0) @db.Decimal(14, 2)
  employerChargeAmount    Decimal @default(0) @db.Decimal(14, 2)
  netPayableAmount        Decimal @default(0) @db.Decimal(14, 2)
  currency                String  @default("XAF")

  documentHash String
  archiveUri   String?
  metadata     Json?

  lines              PayrollPayslipLine[]
  paymentAllocations PayrollPaymentAllocation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, payslipNumber])
  @@index([organizationId, payrollRunId])
  @@index([organizationId, employeeId, issuedAt])
  @@map("payroll_payslips")
}

model PayrollPayslipLine {
  id String @id @default(cuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  payslipId String
  payslip   PayrollPayslip @relation(fields: [payslipId], references: [id], onDelete: Cascade)

  lineNumber Int
  code       String
  label      String
  category   PayrollPayslipLineCategory

  baseAmount Decimal? @db.Decimal(14, 2)
  rateBps    Int?
  amount     Decimal  @default(0) @db.Decimal(14, 2)
  currency   String   @default("XAF")

  sourceType String?
  sourceId   String?
  metadata   Json?

  createdAt DateTime @default(now())

  @@unique([payslipId, lineNumber])
  @@index([organizationId, payslipId])
  @@map("payroll_payslip_lines")
}

model PayrollDeclaration {
  id String @id @default(cuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  payrollRunId String
  payrollRun   PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Restrict)

