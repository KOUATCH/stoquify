// Modern POS/Inventory/Financial Management System Schema
// Refinements applied in this revision:
//   * Multi-tenant performance — compound indexes starting with organizationId
//     on every hot query path; status/date/deletedAt composite indexes
//   * Bilingual EN/FR — separate columns (nameEn required, nameFr optional)
//     on translatable user-facing fields; preferredLocale on Org/User/Customer
//   * Soft deletes — deletedAt on financial entities (Item, Customer, Supplier,
//     SalesOrder, PurchaseOrder, Payment, etc.) — preserves historical reports
//   * Optimistic locking — version column on InventoryLevel to prevent oversell
//     race conditions in concurrent POS sales
//   * Idempotency — idempotencyKey on Payment to prevent duplicate mobile-money
//     charges from retry storms
//   * Per-org uniqueness on all document numbers (orderNumber, receiptNumber,
//     adjustmentNumber, etc.) — was previously globally unique, which would
//     collide across tenants
//   * Bug fixes from prior review: PasswordHistory relation, SerialNumber
//     relation + org scoping, OAuth-compatible nullable password,
//     DailySalesReport.reportGeneratedBy as proper relation, Item.imageUrls
//     as String[], dropped Item name uniqueness, removed dead User.name field.
//
// Migration notes (NOT auto-handled by `prisma migrate dev`):
//   1. The translatable-name fields (e.g. Item.name -> nameEn) need a data
//      backfill before the old column is dropped. Plan: add new columns,
//      backfill in SQL, then drop old in a follow-up migration.
//   2. For deletedAt to be query-efficient on large tables, add partial
//      indexes via raw migration:
//        CREATE INDEX CONCURRENTLY items_active_idx
//          ON items (organization_id) WHERE deleted_at IS NULL;
//      Prisma's @@index doesn't support partial indexes yet (as of 5.x).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// SHARED ENUMS
// ============================================================

enum Locale {
  EN
  FR
}

// ============================================================
// AUTHENTICATION & AUTHORIZATION
// ============================================================

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verifications")
}

model User {
  id            String  @id @default(cuid())
  name          String?
  email         String  @unique
  emailVerified Boolean @default(false)
  firstName     String?
  lastName      String?
  phone         String? @unique
  image         String?
  jobTitle      String?
  password      String? // nullable: OAuth users won't have one
  isActive      Boolean @default(true)
  isVerified    Boolean @default(false)

  // User's UI / receipt language preference
  preferredLocale Locale @default(EN)

  // Verification & password reset
  verificationToken        String?
  verificationTokenExpires DateTime?

  // Account security (login throttling & locking)
  isLocked            Boolean   @default(false)
  lockedUntil         DateTime?
  failedLoginAttempts Int       @default(0)
  lastFailedLogin     DateTime?
  lastLogin           DateTime?

  // MFA — TOTP shared secret, encrypted at rest with MFA_ENCRYPTION_KEY.
  // Null while MFA is disabled. `mfaEnabledAt` is the source of truth for
  // "is MFA on for this account"; presence of a secret alone isn't enough.
  mfaSecret      String?
  mfaEnabledAt   DateTime?
  // Hashed single-use backup codes (10 by default). The user sees the
  // plaintext once at enrolment; only the hash is persisted.
  mfaBackupCodes String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Organization (required — created together in signup transaction)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Role relationships
  roles Role[] @relation("UserRoles")

  // Authentication
  accounts Account[]
  sessions Session[]

  // Location management
  managedLocations Location[] @relation("LocationManager")

  // Transaction tracking
  createdTransactions    InventoryTransaction[] @relation("TransactionCreatedBy")
  createdPurchaseOrders  PurchaseOrder[]        @relation("PurchaseOrderCreatedBy")
  approvedPurchaseOrders PurchaseOrder[]        @relation("PurchaseOrderApprovedBy")
  createdSalesOrders     SalesOrder[]           @relation("SalesOrderCreatedBy")
  createdAdjustments     StockAdjustment[]      @relation("AdjustmentCreatedBy")
  approvedAdjustments    StockAdjustment[]      @relation("AdjustmentApprovedBy")
  createdTransfers       StockTransfer[]        @relation("TransferCreatedBy")
  approvedTransfers      StockTransfer[]        @relation("TransferApprovedBy")
  receivedGoodsReceipts  GoodsReceipt[]         @relation("GoodsReceiptReceivedBy")

  // POS relationships
  posSessions            POSSession[]
  cashDrawerTransactions CashDrawerTransaction[]
  paymentsProcessed      Payment[]
  refundsProcessed       PaymentRefund[]

  // Production
  createdProductionBatches ProductionBatch[] @relation("ProductionCreatedBy")

  // Expenses
  createdExpenses Expense[] @relation("ExpenseCreatedBy")

  // Reports
  generatedReports DailySalesReport[] @relation("ReportGeneratedBy")

  // Audit
  auditLogs       AuditLog[]
  passwordHistory PasswordHistory[]

  importedStatementFiles       StatementFile[]     @relation("StatementFileImportedBy")
  matchedPaymentRecords        MatchRecord[]       @relation("MatchRecordMatchedBy")
  ownedSuspenseItems           SuspenseItem[]      @relation("SuspenseItemOwner")
  runPaymentReconciliations    ReconciliationRun[] @relation("ReconciliationRunRunBy")
  signedPaymentReconciliations ReconciliationRun[] @relation("ReconciliationRunSignedBy")
  ownedPaymentExceptions       PaymentException[]  @relation("PaymentExceptionOwner")
  stockCountsCreated           StockCountSession[] @relation("StockCountCreatedBy")
  stockCountsSubmitted         StockCountSession[] @relation("StockCountSubmittedBy")
  stockCountsApproved          StockCountSession[] @relation("StockCountApprovedBy")
  stockCountsPosted            StockCountSession[] @relation("StockCountPostedBy")

  @@index([organizationId])
  @@index([organizationId, isActive])
  @@index([email])
  @@index([phone])
  @@map("users")
}

model Role {
  id          String  @id @default(cuid())
  code        String // System code, e.g. "CASHIER"
  description String?

  // Bilingual display
  nameEn String
  nameFr String?

  permissions    String[] // Array of permission strings
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users          User[]       @relation("UserRoles")
  invites        Invite[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("roles")
}

// ============================================================
// ORGANIZATION & LOCATIONS
// ============================================================

model Organization {
  id                 String    @id @default(cuid())
  name               String
  slug               String // per-org unique handled at app + index; tenants don't share slug space anyway
  industry           String?
  tradeName          String?
  taxIdentifier      String?
  country            String?
  countryCode        String?
  state              String?
  address            String?
  currency           String    @default("XAF") // FCFA default — adjust per tenant
  timezone           String    @default("Africa/Douala")
  defaultLocale      Locale    @default(EN)
  companySize        String?
  businessType       String?
  branchCount        String?
  primaryPain        String?
  setupRole          String?
  requestedModules   String[]  @default([])
  assistedSetupRequested Boolean @default(false)
  onboardingSource   String?
  onboardingCompletedAt DateTime?
  inventoryStartDate DateTime?
  fiscalYearStart    String?   @default("01-01") // MM-DD
  isActive           Boolean   @default(true)
  deletedAt          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Relationships
  users                 User[]
  invites               Invite[]
  roles                 Role[]
  locations             Location[]
  items                 Item[]
  categories            Category[]
  brands                Brand[]
  units                 Unit[]
  taxRates              TaxRate[]
  suppliers             Supplier[]
  customers             Customer[]
  purchaseOrders        PurchaseOrder[]
  salesOrders           SalesOrder[]
  stockAdjustments      StockAdjustment[]
  stockTransfers        StockTransfer[]
  goodsReceipts         GoodsReceipt[]
  inventoryTransactions InventoryTransaction[]
  serialNumbers         SerialNumber[]
  posStations           POSStation[]
  dailySalesReports     DailySalesReport[]
  payments              Payment[]

  recipes                  Recipe[]
  productionBatches        ProductionBatch[]
  expenseCategories        ExpenseCategory[]
  expenses                 Expense[]
  customerLedgerEntries    CustomerLedgerEntry[]
  supplierLedgerEntries    SupplierLedgerEntry[]
  accountingSettings       OrganizationAccountingSettings?
  fiscalYears              FiscalYear[]
  accountingPeriods        AccountingPeriod[]
  chartOfAccounts          ChartOfAccount[]
  journals                 Journal[]
  journalEntries           JournalEntry[]
  journalEntryLines        JournalEntryLine[]
  ledgerPostingBatches     LedgerPostingBatch[]
  accountingSourceLinks    AccountingSourceLink[]
  postingRules             PostingRule[]
  postingRuleLines         PostingRuleLine[]
  ledgerAuditEvents        LedgerAuditEvent[]
  businessEvents           BusinessEvent[]
  businessEventOutbox      BusinessEventOutbox[]
  auditLogs                AuditLog[]
  posOfflineDevices        POSOfflineDevice[]
  posOfflineSyncBatches    POSOfflineSyncBatch[]
  posOfflineEvents         POSOfflineEvent[]
  posOfflineSyncConflicts  POSOfflineSyncConflict[]
  posOfflineSyncCertificates POSOfflineSyncCertificate[]
  payrollEmployees         PayrollEmployee[]
  payrollContracts         PayrollContract[]
  payrollPeriods           PayrollPeriod[]
  payrollAttendanceSnapshots PayrollAttendanceSnapshot[]
  payrollRuns              PayrollRun[]
  payrollRunLines          PayrollRunLine[]
  payrollPayslips          PayrollPayslip[]
  payrollPayslipLines      PayrollPayslipLine[]
  payrollDeclarations      PayrollDeclaration[]
  payrollPaymentBatches    PayrollPaymentBatch[]
  payrollPaymentAllocations PayrollPaymentAllocation[]
  paymentRails             PaymentRail[]
  providerAccounts         ProviderAccount[]
  settlementAccounts       SettlementAccount[]
  providerEvents           ProviderEvent[]
  statementFiles           StatementFile[]
  statementLines           StatementLine[]
  paymentTransactions      PaymentTransaction[]
  matchRecords             MatchRecord[]
  suspenseItems            SuspenseItem[]
  reconciliationRuns       ReconciliationRun[]
  paymentExceptions        PaymentException[]
  reconciliationInbox      PaymentReconciliationInboxItem[]
  closeRuns                CloseRun[]
  closeChecklistItems      CloseChecklistItem[]
  closeAssuranceFindings   CloseAssuranceFinding[]
  closeEvidenceItems       CloseEvidenceItem[]
  closePackExports         ClosePackExport[]
  accountantReviews        AccountantReview[]
  accountantComments       AccountantComment[]
  fiscalDocuments          FiscalDocument[]
  fiscalDocumentLines      FiscalDocumentLine[]
  fiscalSequences          FiscalSequence[]
  complianceSubmissions    ComplianceSubmission[]
  complianceAdapterConfigs ComplianceAdapterConfig[]
  complianceEvidence       ComplianceEvidence[]
  stockCountSessions       StockCountSession[]
  supplierBankAccounts     SupplierBankAccount[]
  supplierBankChanges      SupplierBankChangeRequest[]
  supplierInvoices         SupplierInvoice[]
  supplierInvoiceLines     SupplierInvoiceLine[]
  threeWayMatches          ThreeWayMatch[]
  supplierPayments         SupplierPayment[]
  supplierPaymentAllocations SupplierPaymentAllocation[]

  @@unique([slug])
  @@index([slug])
  @@index([isActive, deletedAt])
  @@map("organizations")
}

model Invite {
  id             String       @id @default(cuid())
  // Opaque 64-char hex token (32 bytes) used as the ONLY identifier in the
  // invite URL. Replaces the previous pattern of putting orgId+roleId+email
  // in the query string, which let recipients self-promote by editing the URL.
  token          String       @unique
  email          String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  // Role to assign on redemption — stored at invite time so the redeemer
  // cannot forge it. FK to a Role row scoped to this organisation.
  roleId         String
  role           Role         @relation(fields: [roleId], references: [id], onDelete: Restrict)
  status         InviteStatus @default(PENDING)
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([email, organizationId])
  @@index([email])
  @@index([organizationId, status])
  @@index([token, status]) // hot path: redeem flow
  @@map("invites")
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

model Location {
  id   String       @id @default(cuid())
  name String // tenant-specific naming (proper noun), no i18n needed
  code String
  type LocationType @default(WAREHOUSE)

  address   String?
  phone     String?
  email     String?
  isActive  Boolean   @default(true)
  isDefault Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  managerId String?
  manager   User?   @relation("LocationManager", fields: [managerId], references: [id])

  allowNegativeStock Boolean @default(false)
  requiresApproval   Boolean @default(false)

  inventoryLevels       InventoryLevel[]
  inventoryTransactions InventoryTransaction[]
  transfersFrom         StockTransfer[]        @relation("TransferFrom")
  transfersTo           StockTransfer[]        @relation("TransferTo")
  purchaseOrders        PurchaseOrder[]
  salesOrders           SalesOrder[]
  stockAdjustments      StockAdjustment[]
  goodsReceipts         GoodsReceipt[]
  posStations           POSStation[]
  cashDrawers           CashDrawer[]
  dailySalesReports     DailySalesReport[]
  posSessions           POSSession[]
  posOfflineDevices     POSOfflineDevice[]
  posOfflineEvents      POSOfflineEvent[]
  posOfflineSyncCertificates POSOfflineSyncCertificate[]
  productionBatches     ProductionBatch[]
  expenses              Expense[]
  serialNumbers         SerialNumber[]
  stockCountSessions    StockCountSession[]
  stockCountLines       StockCountLine[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([organizationId, type, isActive])
  @@map("locations")
}

enum LocationType {
  WAREHOUSE
  STORE
  DISTRIBUTION_CENTER
  SUPPLIER
  CUSTOMER
  MANUFACTURING
  QUARANTINE
  DAMAGED
  TRANSIT
  VIRTUAL
}

// ============================================================
// PRODUCT CATALOG (i18n applied)
// ============================================================

model Category {
  id   String @id @default(cuid())
  slug String

  // Bilingual
  titleEn       String
  titleFr       String?
  descriptionEn String?
  descriptionFr String?

  imageUrl       String?
  parentId       String?
  parent         Category?    @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children       Category[]   @relation("CategoryHierarchy")
  isActive       Boolean      @default(true)
  deletedAt      DateTime?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  items          Item[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([organizationId, parentId])
  @@index([organizationId, isActive, deletedAt])
  @@map("categories")
}

model Brand {
  id   String @id @default(cuid())
  slug String

  // Bilingual brand name. Many brands ARE proper nouns ("Coca-Cola", "Samsung")
  // and will use the same nameEn / nameFr value, but markets with localized
  // brand names (e.g. KFC → PFK in Québec) need this column pair to differ.
  nameEn String
  nameFr String?

  // Description can also vary by language
  descriptionEn String?
  descriptionFr String?

  logoUrl        String?
  isActive       Boolean      @default(true)
  deletedAt      DateTime?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  items          Item[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@map("brands")
}

model Unit {
  id     String   @id @default(cuid())
  symbol String // e.g. "kg" — same in both languages
  type   UnitType @default(QUANTITY)

  // Bilingual full name
  nameEn String // e.g. "kilogram"
  nameFr String? // e.g. "kilogramme"

  baseUnit       String? // For conversions
  conversionRate Decimal? @db.Decimal(18, 6) // Rate to base unit
  isActive       Boolean  @default(true)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  items          Item[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, symbol])
  @@unique([organizationId, nameEn])
  @@index([organizationId])
  @@map("units")
}

enum UnitType {
  QUANTITY
  WEIGHT
  VOLUME
  LENGTH
  AREA
  TIME
}

model TaxRate {
  id   String  @id @default(cuid())
  rate Decimal @db.Decimal(6, 3) // e.g., 19.250 for VAT
  type TaxType @default(SALES)

  // Bilingual display name
  nameEn String // e.g. "VAT 19.25%"
  nameFr String? // e.g. "TVA 19,25%"

  isActive       Boolean      @default(true)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  items          Item[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, nameEn])
  @@index([organizationId])
  @@map("tax_rates")
}

enum TaxType {
  SALES
  VAT
  GST
  EXCISE
  IMPORT
  EXPORT
}

model Item {
  id      String  @id @default(cuid())
  slug    String
  sku     String
  barcode String?

  // Bilingual
  nameEn        String
  nameFr        String?
  descriptionEn String?
  descriptionFr String?

  imageUrls String[] // Postgres native array, not JSON string
  thumbnail String?

  // Product identifiers
  upc  String?
  ean  String?
  mpn  String?
  isbn String?

  // Physical properties
  dimensions String?
  weight     Decimal? @db.Decimal(12, 3)
  color      String?
  size       String?

  // Pricing
  costPrice    Decimal  @default(0) @db.Decimal(12, 2)
  sellingPrice Decimal  @default(0) @db.Decimal(12, 2)
  msrp         Decimal? @db.Decimal(12, 2)

  // Inventory settings
  trackInventory     Boolean  @default(true)
  trackSerialNumbers Boolean  @default(false)
  trackBatches       Boolean  @default(false)
  trackExpiry        Boolean  @default(false)
  minStockLevel      Decimal  @default(0) @db.Decimal(12, 3)
  maxStockLevel      Decimal? @db.Decimal(12, 3)
  reorderLevel       Decimal  @default(0) @db.Decimal(12, 3)
  reorderQuantity    Decimal? @db.Decimal(12, 3)

  // Status
  isActive       Boolean   @default(true)
  isDiscontinued Boolean   @default(false)
  deletedAt      DateTime?

  // Relationships
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  brandId String?
  brand   Brand?  @relation(fields: [brandId], references: [id])

  unitId String?
  unit   Unit?   @relation(fields: [unitId], references: [id])

  taxRateId String?
  taxRate   TaxRate? @relation(fields: [taxRateId], references: [id])

  // Inventory and transactions
  inventoryLevels       InventoryLevel[]
  inventoryTransactions InventoryTransaction[]
  serialNumbers         SerialNumber[]

  // Supplier relationships
  supplierItems ItemSupplier[]

  // Order lines
  purchaseOrderLines    PurchaseOrderLine[]
  salesOrderLines       SalesOrderLine[]
  adjustmentLines       StockAdjustmentLine[]
  transferLines         StockTransferLine[]
  goodsReceiptLines     GoodsReceiptLine[]
  supplierInvoiceLines  SupplierInvoiceLine[]
  stockCountLines       StockCountLine[]

  // Production
  recipesAsOutput     Recipe[]           @relation("RecipeOutput")
  recipesAsIngredient RecipeIngredient[] @relation("RecipeIngredient")

  // Reporting snapshots
  dailySalesReportItems DailySalesReportItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Uniqueness: SKU and barcode (when set) must be unique per org.
  // Name is NOT unique — two items can share a name briefly (e.g. variants
  // mid-data-entry) and that's legitimate.
  @@unique([organizationId, sku])
  @@unique([organizationId, slug])
  @@unique([organizationId, barcode])
  @@index([organizationId])
  @@index([barcode]) // POS scanner lookup
  @@index([organizationId, isActive, deletedAt]) // hot path: list active items
  @@index([organizationId, categoryId, deletedAt]) // hot path: browse by category
  @@index([organizationId, brandId])
  @@map("items")
}

// ============================================================
// INVENTORY
// ============================================================

model InventoryLevel {
  id         String   @id @default(cuid())
  itemId     String
  item       Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  // Current quantities
  quantityOnHand    Decimal @default(0) @db.Decimal(12, 3)
  quantityReserved  Decimal @default(0) @db.Decimal(12, 3)
  quantityAvailable Decimal @default(0) @db.Decimal(12, 3)
  quantityInTransit Decimal @default(0) @db.Decimal(12, 3)
  quantityOnOrder   Decimal @default(0) @db.Decimal(12, 3)
  reorderPoint      Decimal @default(0) @db.Decimal(12, 3)

  // Valuation (weighted average cost)
  averageCost Decimal @default(0) @db.Decimal(12, 2)
  totalValue  Decimal @default(0) @db.Decimal(14, 2)

  // Optimistic locking — increment on every update, fail if mismatched.
  // Prevents oversell when two POS terminals sell the last unit simultaneously.
  version Int @default(0)

  // Last updated
  lastCountDate     DateTime?
  lastTransactionAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([itemId, locationId])
  @@index([itemId])
  @@index([locationId])
  @@map("inventory_levels")
}

model InventoryTransaction {
  id        String          @id @default(cuid())
  type      TransactionType
  quantity  Decimal         @db.Decimal(12, 3) // signed: + inbound, - outbound
  unitCost  Decimal         @default(0) @db.Decimal(12, 2)
  totalCost Decimal         @default(0) @db.Decimal(14, 2)
  notes     String?
  createdAt DateTime        @default(now())

  itemId     String
  item       Item     @relation(fields: [itemId], references: [id])
  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdById    String?
  createdBy      User?        @relation("TransactionCreatedBy", fields: [createdById], references: [id])

  // Reference tracking
  referenceType   TransactionReferenceType?
  referenceId     String?
  referenceNumber String?

  // Batch and serial tracking
  batchNumber   String?
  serialNumbers String[]
  expiryDate    DateTime?

  balanceAfter Decimal @db.Decimal(12, 3)

  @@index([itemId])
  @@index([locationId])
  @@index([organizationId, createdAt]) // hot: org-scoped time-range
  @@index([itemId, createdAt]) // hot: item history
  @@index([type])
  @@index([referenceType, referenceId])
  @@map("inventory_transactions")
}

enum TransactionType {
  // Inbound
  PURCHASE_RECEIPT
  SALES_RETURN
  TRANSFER_IN
  ADJUSTMENT_IN
  PRODUCTION_IN
  INITIAL_STOCK

  // Outbound
  SALE
  PURCHASE_RETURN
  TRANSFER_OUT
  ADJUSTMENT_OUT
  PRODUCTION_OUT
  DAMAGED
  EXPIRED
  THEFT
  WRITE_OFF
  SAMPLE
  PROMOTION

  // Reservations
  RESERVATION
  RESERVATION_RELEASE
}

enum TransactionReferenceType {
  SALES_ORDER
  PURCHASE_ORDER
  STOCK_TRANSFER
  STOCK_ADJUSTMENT
  GOODS_RECEIPT
  PRODUCTION_BATCH
  RETURN
  MANUAL
}

model SerialNumber {
  id           String       @id @default(cuid())
  serialNumber String
  status       SerialStatus @default(AVAILABLE)

  itemId String
  item   Item   @relation(fields: [itemId], references: [id])

  // Now a proper relation (was a dangling string before)
  locationId String?
  location   Location? @relation(fields: [locationId], references: [id])

  // Scoped to org so SN lookups never leak across tenants
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  batchNumber String?
  expiryDate  DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([organizationId, serialNumber]) // unique per org, not globally
  @@index([itemId])
  @@index([organizationId, status])
  @@map("serial_numbers")
}

enum SerialStatus {
  AVAILABLE
  RESERVED
  SOLD
  DAMAGED
  RETURNED
  EXPIRED
}

// ============================================================
// SUPPLIERS
// ============================================================

model Supplier {
  id            String   @id @default(cuid())
  name          String // legal/business name, no i18n
  code          String?
  contactPerson String?
  email         String?
  phone         String?
  address       String?
  city          String?
  state         String?
  zipCode       String?
  country       String?
  taxId         String?
  paymentTerms  Int?     @default(30)
  creditLimit   Decimal? @db.Decimal(14, 2)
  notes         String?
  isActive      Boolean  @default(true)

  // Supplier's preferred language for POs/emails
  preferredLocale Locale @default(EN)

  // Running balance (positive = we owe them)
  currentBalance Decimal @default(0) @db.Decimal(14, 2)

  deletedAt DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  supplierItems  ItemSupplier[]
  purchaseOrders PurchaseOrder[]
  expenses       Expense[]
  ledgerEntries  SupplierLedgerEntry[]
  bankAccounts   SupplierBankAccount[]
  bankChanges    SupplierBankChangeRequest[]
  supplierInvoices SupplierInvoice[]
  supplierPayments SupplierPayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([organizationId, isActive, deletedAt])
  @@map("suppliers")
}

model ItemSupplier {
  id               String    @id @default(cuid())
  itemId           String
  item             Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)
  supplierId       String
  supplier         Supplier  @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  supplierSku      String?
  supplierName     String?
  isPreferred      Boolean   @default(false)
  leadTimeDays     Int?
  minOrderQuantity Decimal?  @db.Decimal(12, 3)
  unitCost         Decimal?  @db.Decimal(12, 2)
  lastPurchaseDate DateTime?
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([itemId, supplierId])
  @@index([supplierId])
  @@map("item_suppliers")
}

// ============================================================
// CUSTOMERS
// ============================================================

model Customer {
  id           String   @id @default(cuid())
  name         String // person/business name, no i18n
  code         String?
  email        String?
  phone        String?
  address      String?
  taxId        String?
  creditLimit  Decimal? @db.Decimal(14, 2)
  paymentTerms Int?     @default(30)
  notes        String?
  isActive     Boolean  @default(true)

  // Customer's preferred language — drives receipt printing & SMS language
  preferredLocale Locale @default(EN)

  // Running balance (positive = they owe us)
  currentBalance Decimal @default(0) @db.Decimal(14, 2)

  deletedAt DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  salesOrders   SalesOrder[]
  ledgerEntries CustomerLedgerEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([organizationId, isActive, deletedAt])
  @@index([email])
  @@index([phone])
  @@map("customers")
}

// ============================================================
// PURCHASE ORDERS
// ============================================================

model PurchaseOrder {
  id                   String              @id @default(cuid())
  orderNumber          String // per-org unique, not globally
  status               PurchaseOrderStatus @default(DRAFT)
  orderDate            DateTime            @default(now())
  expectedDeliveryDate DateTime?
  actualDeliveryDate   DateTime?
  paymentTerms         String?
  notes                String?
  internalNotes        String?

  // Totals
  subtotal     Decimal @default(0) @db.Decimal(14, 2)
  taxAmount    Decimal @default(0) @db.Decimal(14, 2)
  shippingCost Decimal @default(0) @db.Decimal(14, 2)
  discount     Decimal @default(0) @db.Decimal(14, 2)
  total        Decimal @default(0) @db.Decimal(14, 2)

  deletedAt DateTime?

  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdById String?
  createdBy   User?   @relation("PurchaseOrderCreatedBy", fields: [createdById], references: [id])

  approvedById String?
  approvedBy   User?     @relation("PurchaseOrderApprovedBy", fields: [approvedById], references: [id])
  approvedAt   DateTime?

  lines         PurchaseOrderLine[]
  goodsReceipts GoodsReceipt[]
  payments      Payment[]
  supplierInvoices SupplierInvoice[]
  threeWayMatches  ThreeWayMatch[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, orderNumber])
  @@index([supplierId])
  @@index([organizationId, status, orderDate])
  @@index([organizationId, orderDate])
  @@index([locationId])
  @@map("purchase_orders")
}

enum PurchaseOrderStatus {
  DRAFT
  SUBMITTED
  APPROVED
  PARTIALLY_RECEIVED
  RECEIVED
  COMPLETED
  CANCELLED
}

model PurchaseOrderLine {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  itemId          String
  item            Item          @relation(fields: [itemId], references: [id])

  orderedQuantity  Decimal @db.Decimal(12, 3)
  receivedQuantity Decimal @default(0) @db.Decimal(12, 3)
  unitCost         Decimal @db.Decimal(12, 2)
  discount         Decimal @default(0) @db.Decimal(14, 2)
  taxRate          Decimal @default(0) @db.Decimal(6, 3)
  taxAmount        Decimal @default(0) @db.Decimal(14, 2)
  lineTotal        Decimal @db.Decimal(14, 2)
  notes            String?

  goodsReceiptLines    GoodsReceiptLine[]
  supplierInvoiceLines SupplierInvoiceLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([purchaseOrderId])
  @@index([itemId])
  @@map("purchase_order_lines")
}

// ============================================================
// GOODS RECEIPT
// ============================================================

model GoodsReceipt {
  id              String             @id @default(cuid())
  receiptNumber   String // per-org unique
  receiptDate     DateTime           @default(now())
  status          GoodsReceiptStatus @default(DRAFT)
  notes           String?
  purchaseOrderId String
  purchaseOrder   PurchaseOrder      @relation(fields: [purchaseOrderId], references: [id])

  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  receivedById String?
  receivedBy   User?   @relation("GoodsReceiptReceivedBy", fields: [receivedById], references: [id])

  lines           GoodsReceiptLine[]
  threeWayMatches ThreeWayMatch[]

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([organizationId, receiptNumber])
  @@index([purchaseOrderId])
  @@index([organizationId, status, receiptDate])
  @@index([locationId])
  @@map("goods_receipts")
}

enum GoodsReceiptStatus {
  DRAFT
  RECEIVED
  COMPLETED
  CANCELLED
}

model GoodsReceiptLine {
  id                  String            @id @default(cuid())
  goodsReceiptId      String
  goodsReceipt        GoodsReceipt      @relation(fields: [goodsReceiptId], references: [id], onDelete: Cascade)
  purchaseOrderLineId String
  purchaseOrderLine   PurchaseOrderLine @relation(fields: [purchaseOrderLineId], references: [id])
  itemId              String
  item                Item              @relation(fields: [itemId], references: [id])

  receivedQuantity Decimal   @db.Decimal(12, 3)
  unitCost         Decimal   @db.Decimal(12, 2)
  lineTotal        Decimal   @db.Decimal(14, 2)
  notes            String?
  batchNumber      String?
  expiryDate       DateTime?

  supplierInvoiceLines SupplierInvoiceLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([goodsReceiptId])
  @@index([purchaseOrderLineId])
  @@index([itemId])
  @@map("goods_receipt_lines")
}

// ============================================================
// PURCHASING AP CONTROL KERNEL
// ============================================================

enum SupplierBankAccountStatus {
  PENDING_APPROVAL
  APPROVED
  SUSPENDED
  ARCHIVED
}

enum SupplierBankChangeStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum SupplierInvoiceStatus {
  DRAFT
  MATCHED
  POSTED
  PAYMENT_PENDING
  PAID
  CANCELLED
  DISPUTED
}

enum ThreeWayMatchStatus {
  MATCHED
  EXCEPTION
  APPROVED_EXCEPTION
  REJECTED
}

enum SupplierPaymentStatus {
  DRAFT
  APPROVED
  RELEASED
  POSTED
  CANCELLED
  FAILED
}

model SupplierBankAccount {
  id String @id @default(cuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  bankName              String?
  accountName           String?
  accountNumberMasked   String?
  accountNumberHash     String?
  mobileMoneyProvider   String?
  mobileMoneyPhoneMasked String?
  mobileMoneyPhoneHash   String?

  isPrimary Boolean @default(false)
  status    SupplierBankAccountStatus @default(PENDING_APPROVAL)

  requestedById String?
  approvedById  String?
  approvedAt    DateTime?
  suspendedAt   DateTime?

  evidenceHash String?
  documentHash String?
  metadata     Json?
  deletedAt    DateTime?

  changeRequests  SupplierBankChangeRequest[]
  supplierPayments SupplierPayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, supplierId, status])
  @@index([organizationId, accountNumberHash])
  @@index([organizationId, mobileMoneyPhoneHash])
  @@map("supplier_bank_accounts")
}

model SupplierBankChangeRequest {
  id String @id @default(cuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  bankAccountId String?
  bankAccount   SupplierBankAccount? @relation(fields: [bankAccountId], references: [id])

  status SupplierBankChangeStatus @default(PENDING)

  requestedById String
  approvedById  String?
  requestedAt   DateTime @default(now())
  approvedAt    DateTime?
  rejectedAt    DateTime?
  reason        String?

  newBankName              String?
  newAccountName           String?
  newAccountNumberMasked   String?
  newAccountNumberHash     String?
  newMobileMoneyProvider   String?
  newMobileMoneyPhoneMasked String?
  newMobileMoneyPhoneHash   String?

  changeHash  String
  documentHash String?
  metadata     Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, supplierId, status, requestedAt])
  @@index([bankAccountId])
  @@map("supplier_bank_change_requests")
}

model SupplierInvoice {
  id String @id @default(cuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Restrict)

  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])

  invoiceNumber String
  invoiceDate   DateTime
  dueDate       DateTime?
  status        SupplierInvoiceStatus @default(DRAFT)

  subtotal   Decimal @default(0) @db.Decimal(14, 2)
  taxAmount  Decimal @default(0) @db.Decimal(14, 2)
  discount   Decimal @default(0) @db.Decimal(14, 2)
  total      Decimal @default(0) @db.Decimal(14, 2)
  amountPaid Decimal @default(0) @db.Decimal(14, 2)
  currency   String  @default("XAF")

  duplicateFingerprint String
  idempotencyKey       String?
  documentHash         String?
  evidenceHash         String?
  postedBusinessEventId String?
  ledgerPostingBatchId  String?

  createdById  String?
  approvedById String?
  postedAt     DateTime?
  cancelledAt  DateTime?
  notes        String?
  metadata     Json?
  deletedAt    DateTime?

  lines              SupplierInvoiceLine[]
  threeWayMatches    ThreeWayMatch[]
  paymentAllocations SupplierPaymentAllocation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, supplierId, invoiceNumber])
  @@unique([organizationId, idempotencyKey])
  @@unique([organizationId, duplicateFingerprint])
  @@index([organizationId, status, invoiceDate])
  @@index([supplierId, status])
  @@index([purchaseOrderId])
  @@map("supplier_invoices")
}

model SupplierInvoiceLine {
  id String @id @default(cuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  supplierInvoiceId String
  supplierInvoice   SupplierInvoice @relation(fields: [supplierInvoiceId], references: [id], onDelete: Cascade)

  purchaseOrderLineId String?
  purchaseOrderLine   PurchaseOrderLine? @relation(fields: [purchaseOrderLineId], references: [id])

  goodsReceiptLineId String?
  goodsReceiptLine   GoodsReceiptLine? @relation(fields: [goodsReceiptLineId], references: [id])

  itemId String?
  item   Item? @relation(fields: [itemId], references: [id])

  description String
  quantity    Decimal @db.Decimal(12, 3)
  unitCost    Decimal @db.Decimal(12, 2)
  taxRate     Decimal @default(0) @db.Decimal(6, 3)
  taxAmount   Decimal @default(0) @db.Decimal(14, 2)
  lineTotal   Decimal @db.Decimal(14, 2)
  matchStatus ThreeWayMatchStatus @default(MATCHED)
  notes       String?
  metadata    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, supplierInvoiceId])
  @@index([purchaseOrderLineId])
  @@index([goodsReceiptLineId])
  @@index([itemId])
  @@map("supplier_invoice_lines")
}

model ThreeWayMatch {
  id String @id @default(cuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  supplierInvoiceId String
  supplierInvoice   SupplierInvoice @relation(fields: [supplierInvoiceId], references: [id], onDelete: Cascade)

  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])

  goodsReceiptId String?
  goodsReceipt   GoodsReceipt? @relation(fields: [goodsReceiptId], references: [id])

  status ThreeWayMatchStatus @default(MATCHED)

  matchedAt DateTime @default(now())
  matchedById String?

  toleranceAmount  Decimal @default(0) @db.Decimal(14, 2)
  varianceAmount   Decimal @default(0) @db.Decimal(14, 2)
  quantityVariance Decimal @default(0) @db.Decimal(12, 3)
  priceVariance    Decimal @default(0) @db.Decimal(14, 2)

  evidenceHash String?
  metadata     Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, status, matchedAt])
  @@index([supplierInvoiceId])
  @@index([purchaseOrderId])
  @@index([goodsReceiptId])
  @@map("three_way_matches")
}

model SupplierPayment {
  id String @id @default(cuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Restrict)

  bankAccountId String?
  bankAccount   SupplierBankAccount? @relation(fields: [bankAccountId], references: [id])

  paymentNumber String
  status        SupplierPaymentStatus @default(DRAFT)
  method        PaymentMethod
  amount        Decimal @db.Decimal(14, 2)
  currency      String  @default("XAF")
  paymentDate   DateTime @default(now())

  idempotencyKey String?
  documentHash   String?
  evidenceHash   String?

  requestedById String
  approvedById  String?
  releasedById  String?
  approvedAt    DateTime?
  releasedAt    DateTime?

  ledgerPostingBatchId  String?
  postedBusinessEventId String?
  notes                 String?
  metadata              Json?
  deletedAt             DateTime?

  allocations SupplierPaymentAllocation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, paymentNumber])
  @@unique([organizationId, idempotencyKey])
  @@index([organizationId, status, paymentDate])
  @@index([supplierId, status])
  @@index([bankAccountId])
  @@map("supplier_payments")
}

model SupplierPaymentAllocation {
  id String @id @default(cuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  supplierPaymentId String
  supplierPayment   SupplierPayment @relation(fields: [supplierPaymentId], references: [id], onDelete: Cascade)

  supplierInvoiceId String
  supplierInvoice   SupplierInvoice @relation(fields: [supplierInvoiceId], references: [id], onDelete: Restrict)

  amount Decimal @db.Decimal(14, 2)

  createdAt DateTime @default(now())

  @@unique([supplierPaymentId, supplierInvoiceId])
  @@index([organizationId, supplierInvoiceId])
  @@map("supplier_payment_allocations")
}

