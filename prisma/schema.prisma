model Payment {
  id            String        @id @default(cuid())
  paymentNumber String // per-org unique
  amount        Decimal       @db.Decimal(14, 2)
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)

  // Idempotency: client supplies on retry to dedupe duplicate charges.
  // Critical for Mobile Money where network flakiness causes retries.
  idempotencyKey String?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  salesOrderId String?
  salesOrder   SalesOrder? @relation(fields: [salesOrderId], references: [id])

  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])

  // Cash specifics
  cashTendered Decimal? @db.Decimal(14, 2)
  changeGiven  Decimal? @db.Decimal(14, 2)

  // Card specifics
  cardType          String?
  cardLast4         String?
  authorizationCode String?

  // Mobile Money specifics
  mobileMoneyProvider    MobileMoneyProvider?
  mobileMoneyPhoneNumber String?
  mobileMoneyReference   String? // operator's transaction id
  mobileMoneyStatus      String?
  mobileMoneyFeesAmount  Decimal?             @db.Decimal(12, 2)

  // Bank transfer specifics
  bankReference String?
  bankName      String?

  // Cheque specifics
  chequeNumber String?
  chequeBank   String?
  chequeDate   DateTime?

  // Generic processor fields
  transactionId     String?
  processedAt       DateTime?
  processorResponse String?

  processedById String?
  processedBy   User?   @relation(fields: [processedById], references: [id])

  refundedAmount            Decimal             @default(0) @db.Decimal(14, 2)
  refunds                   PaymentRefund[]
  reconciliationTransaction PaymentTransaction?

  notes String?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([organizationId, paymentNumber])
  @@unique([organizationId, idempotencyKey])
  @@unique([organizationId, method, transactionId], map: "payments_org_method_txn_key")
  @@unique([organizationId, method, authorizationCode], map: "payments_org_method_auth_key")
  @@unique([organizationId, mobileMoneyProvider, mobileMoneyReference], map: "payments_org_momo_ref_key")
  @@unique([organizationId, method, bankReference], map: "payments_org_method_bank_ref_key")
  @@index([organizationId, createdAt]) // hot: daily reconciliation
  @@index([organizationId, method, status])
  @@index([salesOrderId])
  @@index([purchaseOrderId])
  @@index([mobileMoneyReference]) // looking up by operator ref
  @@map("payments")
}

enum PaymentMethod {
