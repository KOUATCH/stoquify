// ============================================================
// SALES ORDERS
// ============================================================

model SalesOrder {
  id          String           @id @default(cuid())
  orderNumber String
  status      SalesOrderStatus @default(DRAFT)
  orderDate   DateTime         @default(now())
  dueDate     DateTime?
  notes       String?

  // Totals
  subtotal     Decimal @default(0) @db.Decimal(14, 2)
  taxAmount    Decimal @default(0) @db.Decimal(14, 2)
  shippingCost Decimal @default(0) @db.Decimal(14, 2)
  discount     Decimal @default(0) @db.Decimal(14, 2)
  total        Decimal @default(0) @db.Decimal(14, 2)

  paymentStatus PaymentStatus @default(PENDING)

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdById String?
  createdBy   User?   @relation("SalesOrderCreatedBy", fields: [createdById], references: [id])

  terminalId String?
  terminal   POSStation? @relation(fields: [terminalId], references: [id])

  sessionId String?
  session   POSSession? @relation(fields: [sessionId], references: [id])

  lines    SalesOrderLine[]
  payments Payment[]

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([organizationId, orderNumber])
  @@index([customerId])
  @@index([organizationId, orderDate]) // hot: daily reports
  @@index([organizationId, locationId, orderDate]) // hot: location-scoped daily
  @@index([organizationId, status, orderDate])
  @@index([organizationId, paymentStatus])
  @@index([locationId])
  @@map("sales_orders")
}

enum SalesOrderStatus {
  DRAFT
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
  RETURNED
}

model SalesOrderLine {
  id           String     @id @default(cuid())
  salesOrderId String
  salesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  itemId       String
  item         Item       @relation(fields: [itemId], references: [id])

  quantity  Decimal @db.Decimal(12, 3)
  unitPrice Decimal @db.Decimal(12, 2)
  discount  Decimal @default(0) @db.Decimal(14, 2)
  taxRate   Decimal @default(0) @db.Decimal(6, 3)
  taxAmount Decimal @default(0) @db.Decimal(14, 2)
  lineTotal Decimal @db.Decimal(14, 2)
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([salesOrderId])
  @@index([itemId])
  @@map("sales_order_lines")
}

// ============================================================
// DAILY SALES REPORTING (precomputed for fast dashboards)
// ============================================================

model DailySalesReport {
  id             String   @id @default(cuid())
  date           DateTime @db.Date
  locationId     String
  organizationId String

  totalRevenue            Decimal @db.Decimal(14, 2)
  totalCost               Decimal @db.Decimal(14, 2)
  grossProfit             Decimal @db.Decimal(14, 2)
  grossMargin             Decimal @db.Decimal(5, 2)
  totalQuantitySold       Decimal @db.Decimal(12, 3)
  totalTransactions       Int
  averageTransactionValue Decimal @db.Decimal(14, 2)
  itemsSold               Int

  cashSales         Decimal @db.Decimal(14, 2)
  cardSales         Decimal @db.Decimal(14, 2)
  mobileMoneySales  Decimal @default(0) @db.Decimal(14, 2)
  bankTransferSales Decimal @default(0) @db.Decimal(14, 2)
  creditSales       Decimal @default(0) @db.Decimal(14, 2)

  totalExpenses Decimal @default(0) @db.Decimal(14, 2)
  netProfit     Decimal @default(0) @db.Decimal(14, 2)

  openingBalance Decimal @db.Decimal(14, 2)
  closingBalance Decimal @db.Decimal(14, 2)
  cashIn         Decimal @db.Decimal(14, 2)
  cashOut        Decimal @db.Decimal(14, 2)
  variance       Decimal @db.Decimal(14, 2)

  reportGeneratedAt   DateTime @default(now())
  reportGeneratedById String?
  reportGeneratedBy   User?    @relation("ReportGeneratedBy", fields: [reportGeneratedById], references: [id])
  isFinalized         Boolean  @default(false)
  notes               String?

  location               Location                    @relation(fields: [locationId], references: [id], onDelete: Cascade)
  organization           Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  itemSales              DailySalesReportItem[]
  cashDrawerTransactions DailySalesReportCashEvent[]

  @@unique([date, locationId, organizationId], name: "date_locationId_organizationId")
  @@index([organizationId, date]) // hot: dashboard range queries
  @@index([locationId, date])
  @@map("daily_sales_reports")
}

model DailySalesReportItem {
  id       String @id @default(cuid())
  reportId String
  itemId   String

  // Snapshot fields (deliberately denormalized — the item's name may change
  // later, but the report should preserve what it looked like that day)
  itemNameEn   String
  itemNameFr   String?
  itemSku      String
  costPrice    Decimal @db.Decimal(12, 2)
  sellingPrice Decimal @db.Decimal(12, 2)

  startingQuantity Decimal @db.Decimal(12, 3)
  quantitySold     Decimal @db.Decimal(12, 3)
  endingQuantity   Decimal @db.Decimal(12, 3)

  cashSales         Decimal @db.Decimal(14, 2)
  cardSales         Decimal @db.Decimal(14, 2)
  mobileMoneySales  Decimal @default(0) @db.Decimal(14, 2)
  bankTransferSales Decimal @default(0) @db.Decimal(14, 2)
  creditSales       Decimal @default(0) @db.Decimal(14, 2)

  totalRevenue Decimal @db.Decimal(14, 2)
  totalCost    Decimal @db.Decimal(14, 2)
  grossProfit  Decimal @db.Decimal(14, 2)
  margin       Decimal @db.Decimal(5, 2)

  report DailySalesReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  item   Item             @relation(fields: [itemId], references: [id])

  @@index([reportId])
  @@index([itemId])
  @@map("daily_sales_report_items")
}

model DailySalesReportCashEvent {
  id              String                    @id @default(cuid())
  reportId        String
  transactionType CashDrawerTransactionType
  amount          Decimal                   @db.Decimal(14, 2)
  reason          String?
  notes           String?
  balanceBefore   Decimal                   @db.Decimal(14, 2)
  balanceAfter    Decimal                   @db.Decimal(14, 2)
  timestamp       DateTime
  userId          String?
  userName        String?

  report DailySalesReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@map("daily_sales_report_cash_events")
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  REFUNDED
  CANCELLED
}

// ============================================================
// STOCK ADJUSTMENTS
// ============================================================

model StockAdjustment {
  id               String           @id @default(cuid())
  adjustmentNumber String // per-org unique
  type             AdjustmentType
  reason           String
  status           AdjustmentStatus @default(DRAFT)
  adjustmentDate   DateTime         @default(now())
  notes            String?

  deletedAt DateTime?

  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdById String?
  createdBy   User?   @relation("AdjustmentCreatedBy", fields: [createdById], references: [id])

  approvedById String?
  approvedBy   User?     @relation("AdjustmentApprovedBy", fields: [approvedById], references: [id])
  approvedAt   DateTime?

  evidenceHash          String?
  documentHash          String?
  postedBusinessEventId String?
  ledgerPostingBatchId  String?
  sourceCountSessionId  String?
  metadata              Json?

  lines StockAdjustmentLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, adjustmentNumber])
  @@index([organizationId, status, adjustmentDate])
  @@index([locationId])
  @@index([sourceCountSessionId])
  @@index([postedBusinessEventId])
  @@index([ledgerPostingBatchId])
  @@map("stock_adjustments")
}

enum AdjustmentType {
  CYCLE_COUNT
  PHYSICAL_COUNT
  DAMAGED
  EXPIRED
  THEFT
  WRITE_OFF
  FOUND
  CORRECTION
  OTHER
}

enum AdjustmentStatus {
  DRAFT
  SUBMITTED
  APPROVED
  COMPLETED
  CANCELLED
}

enum StockCountStatus {
  DRAFT
  FROZEN
  SUBMITTED
  APPROVED
  POSTED
  CANCELLED
}

model StockAdjustmentLine {
  id           String          @id @default(cuid())
  adjustmentId String
  adjustment   StockAdjustment @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)
  itemId       String
  item         Item            @relation(fields: [itemId], references: [id])

  systemQuantity   Decimal  @db.Decimal(12, 3)
  actualQuantity   Decimal  @db.Decimal(12, 3)
  adjustedQuantity Decimal  @db.Decimal(12, 3)
  unitCost         Decimal? @db.Decimal(12, 2)
  totalCost        Decimal? @db.Decimal(14, 2)
  notes            String?
  evidenceHash     String?
  stockCountLineId String?
  metadata         Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([adjustmentId])
  @@index([itemId])
  @@index([stockCountLineId])
  @@map("stock_adjustment_lines")
}

model StockCountSession {
  id          String           @id @default(cuid())
  countNumber String
  status      StockCountStatus @default(DRAFT)
  countDate   DateTime         @default(now())

  snapshotHash   String?
  countSheetHash String?
  notes          String?
  metadata       Json?

  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdById String?
  createdBy   User?   @relation("StockCountCreatedBy", fields: [createdById], references: [id])

  submittedById String?
  submittedBy   User?   @relation("StockCountSubmittedBy", fields: [submittedById], references: [id])
  submittedAt   DateTime?

  approvedById String?
  approvedBy   User?     @relation("StockCountApprovedBy", fields: [approvedById], references: [id])
  approvedAt   DateTime?

