// ============================================================
// POS SYSTEM
// ============================================================

model POSStation {
  id             String  @id @default(cuid())
  terminalNumber String // per-org unique
  name           String
  isActive       Boolean @default(true)

  hasCashDrawer Boolean @default(true)

  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  currentSessionId String?     @unique
  currentSession   POSSession? @relation("StationCurrentSession", fields: [currentSessionId], references: [id])

  sessions    POSSession[] @relation("StationSessions")
  salesOrders SalesOrder[]
  cashDrawers CashDrawer[]
  offlineDevices POSOfflineDevice[]
  offlineEvents POSOfflineEvent[]
  offlineSyncCertificates POSOfflineSyncCertificate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, terminalNumber])
  @@index([locationId])
  @@index([organizationId])
  @@map("pos_terminals")
}

model POSSession {
  id            String           @id @default(cuid())
  sessionNumber String // per-org unique
  status        POSSessionStatus @default(ACTIVE)
  startTime     DateTime         @default(now())
  endTime       DateTime?

  terminalId String
  terminal   POSStation @relation("StationSessions", fields: [terminalId], references: [id])

  stationCurrent POSStation? @relation("StationCurrentSession")

  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  openingBalance  Decimal  @default(0) @db.Decimal(14, 2)
  closingBalance  Decimal? @db.Decimal(14, 2)
  expectedBalance Decimal? @db.Decimal(14, 2)
  variance        Decimal? @db.Decimal(14, 2)

  totalSales       Decimal @default(0) @db.Decimal(14, 2)
  totalTax         Decimal @default(0) @db.Decimal(14, 2)
  totalDiscount    Decimal @default(0) @db.Decimal(14, 2)
  transactionCount Int     @default(0)

  cashTotal         Decimal @default(0) @db.Decimal(14, 2)
  cardTotal         Decimal @default(0) @db.Decimal(14, 2)
  mobileMoneyTotal  Decimal @default(0) @db.Decimal(14, 2)
  bankTransferTotal Decimal @default(0) @db.Decimal(14, 2)
  creditTotal       Decimal @default(0) @db.Decimal(14, 2)

  organizationId String

  salesOrders            SalesOrder[]
  cashDrawerTransactions CashDrawerTransaction[]
  offlineEvents          POSOfflineEvent[]

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, sessionNumber])
  @@index([terminalId])
  @@index([userId])
  @@index([locationId])
  @@index([status, startTime])
  @@map("pos_sessions")
}

enum POSSessionStatus {
  ACTIVE
  SUSPENDED
  CLOSED
  RECONCILED
}

model CashDrawer {
  id              String  @id @default(cuid())
  name            String
  drawerNumber    String
  currentBalance  Decimal @default(0) @db.Decimal(14, 2)
  expectedBalance Decimal @default(0) @db.Decimal(14, 2)
  isOpen          Boolean @default(false)

  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  terminalId String
  terminal   POSStation @relation(fields: [terminalId], references: [id])

  transactions CashDrawerTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locationId])
  @@index([terminalId])
  @@map("cash_drawers")
}

model CashDrawerTransaction {
  id     String                    @id @default(cuid())
  type   CashDrawerTransactionType
  amount Decimal                   @db.Decimal(14, 2)
  reason String?
  notes  String?

  cashDrawerId String
  cashDrawer   CashDrawer @relation(fields: [cashDrawerId], references: [id])

  sessionId String?
  session   POSSession? @relation(fields: [sessionId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  balanceBefore Decimal @db.Decimal(14, 2)
  balanceAfter  Decimal @db.Decimal(14, 2)

  createdAt DateTime @default(now())

  @@index([cashDrawerId, createdAt])
