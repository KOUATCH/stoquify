enum PayrollEmployeeStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  TERMINATED
  ARCHIVED
}

enum PayrollContractType {
  CDI
  CDD
  INTERNSHIP
  DAILY
  CONSULTANT
  OTHER
}

enum PayrollContractStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  ENDED
  CANCELLED
}

enum PayrollPeriodStatus {
  OPEN
