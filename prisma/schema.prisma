model CustomerLedgerEntry {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  entryDate DateTime        @default(now())
  type      LedgerEntryType

  // Debit = customer owes more; Credit = customer paid / earned credit
  debit        Decimal @default(0) @db.Decimal(14, 2)
  credit       Decimal @default(0) @db.Decimal(14, 2)
  balanceAfter Decimal @db.Decimal(14, 2)

  description String

  referenceType String? // "SALES_ORDER", "PAYMENT", "MANUAL"
  referenceId   String?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())

  @@index([customerId, entryDate]) // hot: customer statement query
  @@index([referenceType, referenceId])
  @@index([organizationId, entryDate])
  @@map("customer_ledger_entries")
}

model SupplierLedgerEntry {
  id         String   @id @default(cuid())
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  entryDate DateTime        @default(now())
  type      LedgerEntryType

  // For suppliers: Debit = we owe more; Credit = we paid
  debit        Decimal @default(0) @db.Decimal(14, 2)
  credit       Decimal @default(0) @db.Decimal(14, 2)
  balanceAfter Decimal @db.Decimal(14, 2)

  description String

  referenceType String?
  referenceId   String?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())

  @@index([supplierId, entryDate])
  @@index([referenceType, referenceId])
  @@index([organizationId, entryDate])
  @@map("supplier_ledger_entries")
}

enum LedgerEntryType {
  SALE
  PURCHASE
  PAYMENT
  REFUND
  CREDIT_NOTE
  DEBIT_NOTE
  ADJUSTMENT
  OPENING_BALANCE
  WRITE_OFF
}

