model PayrollEmployee {
  id String @id @default(cuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  userId         String?
  employeeNumber String
  displayName    String
  legalName      String?
  status         PayrollEmployeeStatus @default(DRAFT)

  hireDate        DateTime
  terminationDate DateTime?
  countryCode     String?
  locationId      String?
  department      String?
  jobTitle        String?
  costCenter      String?

  taxIdentifierMasked      String?
  taxIdentifierHash        String?
  socialIdentifierMasked   String?
  socialIdentifierHash     String?
  paymentMethod            PaymentMethod?
  bankAccountMasked        String?
  bankAccountHash          String?
  mobileMoneyProvider      String?
  mobileMoneyPhoneMasked   String?
  mobileMoneyPhoneHash     String?
  paymentDestinationHash   String?

  metadata  Json?
  deletedAt DateTime?

  contracts          PayrollContract[]
  attendanceSnapshots PayrollAttendanceSnapshot[]
  runLines           PayrollRunLine[]
  payslips           PayrollPayslip[]
  paymentAllocations PayrollPaymentAllocation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, employeeNumber])
  @@unique([organizationId, userId])
  @@index([organizationId, status, hireDate])
  @@index([organizationId, paymentDestinationHash])
  @@index([organizationId, socialIdentifierHash])
  @@index([locationId])
  @@map("payroll_employees")
}

model PayrollContract {
  id String @id @default(cuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  employeeId String
  employee   PayrollEmployee @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  contractNumber String
  type           PayrollContractType
  status         PayrollContractStatus @default(DRAFT)

  effectiveFrom DateTime
  effectiveTo   DateTime?
  baseSalary    Decimal @db.Decimal(14, 2)
  currency      String  @default("XAF")

  workingHoursPerMonth Decimal? @db.Decimal(8, 2)
  classification       String?
  echelon              String?
  convention           String?
  signedDocumentHash   String?
  activatedBusinessEventId String?

  metadata  Json?
  deletedAt DateTime?

  runLines PayrollRunLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, contractNumber])
  @@index([organizationId, employeeId, status, effectiveFrom])
  @@index([organizationId, status])
  @@map("payroll_contracts")
}

model PayrollPeriod {
  id String @id @default(cuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  accountingPeriodId String?

  name        String
  frequency   PayrollFrequency @default(MONTHLY)
  periodStart DateTime
  periodEnd   DateTime
  payDate     DateTime
  status      PayrollPeriodStatus @default(OPEN)

  countryCode                   String
  countryPackVersion            String?
  countryPackSchemaVersion      String?
  countryPackResolutionHash     String?
  countryPackCapabilityStatus   String?

  inputLockedAt DateTime?
  inputLockedById String?
  approvedAt     DateTime?
  approvedById   String?
  closedAt       DateTime?
  closedById     String?

  metadata Json?

  attendanceSnapshots PayrollAttendanceSnapshot[]
  runs                PayrollRun[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, periodStart, periodEnd])
  @@index([organizationId, status, periodStart])
  @@index([accountingPeriodId])
  @@map("payroll_periods")
}

model PayrollAttendanceSnapshot {
  id String @id @default(cuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  payrollPeriodId String?
  payrollPeriod   PayrollPeriod? @relation(fields: [payrollPeriodId], references: [id], onDelete: SetNull)

  employeeId String
  employee   PayrollEmployee @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  status      PayrollAttendanceSnapshotStatus @default(DRAFT)
  periodStart DateTime
  periodEnd   DateTime

  scheduledMinutes Int @default(0)
  workedMinutes    Int @default(0)
  overtimeMinutes  Int @default(0)
  absenceMinutes   Int @default(0)
  leaveMinutes     Int @default(0)

  sourceHash   String
  frozenById   String?
  frozenAt     DateTime?
  correctedFromId String?
  correctedFrom   PayrollAttendanceSnapshot?  @relation("AttendanceSnapshotCorrection", fields: [correctedFromId], references: [id])
  corrections     PayrollAttendanceSnapshot[] @relation("AttendanceSnapshotCorrection")

  metadata Json?

  runLines PayrollRunLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, employeeId, periodStart, periodEnd])
  @@index([organizationId, status, frozenAt])
  @@index([payrollPeriodId])
  @@index([correctedFromId])
  @@map("payroll_attendance_snapshots")
}

model PayrollRun {
