  amount      Decimal @default(0) @db.Decimal(14, 2)
  currency    String  @default("XAF")
  payloadHash String?
  metadata    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, payrollRunId, authority, declarationType])
  @@index([organizationId, status, dueDate])
  @@map("payroll_declarations")
}

model PayrollPaymentBatch {
  id String @id @default(cuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  payrollRunId String
  payrollRun   PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Restrict)

