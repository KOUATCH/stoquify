model PayrollPaymentAllocation {
  id String @id @default(cuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  payrollPaymentBatchId String
  payrollPaymentBatch   PayrollPaymentBatch @relation(fields: [payrollPaymentBatchId], references: [id], onDelete: Cascade)

  employeeId String
  employee   PayrollEmployee @relation(fields: [employeeId], references: [id], onDelete: Restrict)

