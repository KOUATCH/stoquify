  @@index([organizationId, status, countDate])
  @@index([locationId])
  @@index([postedBusinessEventId])
  @@index([postedAdjustmentId])
  @@map("stock_count_sessions")
}

model StockCountLine {
  id                  String            @id @default(cuid())
  stockCountSessionId String
  stockCountSession   StockCountSession @relation(fields: [stockCountSessionId], references: [id], onDelete: Cascade)

  itemId String
  item   Item   @relation(fields: [itemId], references: [id])

  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  systemQuantity   Decimal  @db.Decimal(12, 3)
  countedQuantity  Decimal? @db.Decimal(12, 3)
  varianceQuantity Decimal? @db.Decimal(12, 3)
  unitCost         Decimal? @db.Decimal(12, 2)
  varianceValue    Decimal? @db.Decimal(14, 2)
  reasonCode       String?
  evidenceHash     String?
  metadata         Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([stockCountSessionId, itemId, locationId])
  @@index([stockCountSessionId])
  @@index([itemId])
  @@index([locationId])
  @@map("stock_count_lines")
