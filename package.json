{
  "name": "STOQUIFY",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "seed": "ts-node -r tsconfig-paths/register --compiler-options {\"module\":\"CommonJS\",\"moduleResolution\":\"node\"} prisma/comprehensive-seed.ts"
  },
  "scripts": {
    "dev": "npx prisma generate && next dev -p 3000",
    "dev:turbopack": "npx prisma generate && next dev --turbopack -p 3000",
    "build": "npm run build:linted",
    "build:app": "next build",
    "build:linted": "npm run lint && npm run build:app",
    "start": "next start",
    "lint": "eslint app actions components config hooks lib services --ext .js,.jsx,.ts,.tsx",
    "typecheck": "tsc --noEmit --pretty false",
    "prisma:validate": "prisma validate",
    "prisma:generate": "prisma generate",
    "service:boundary": "node scripts/service-boundary-gate.js --mode report",
    "service:boundary:ratchet": "node scripts/service-boundary-gate.js --mode fail --baseline what-next/AQSTOQFLOW_SERVICE_BOUNDARY_GATE_REPORT_2026-06-16.json",
    "service:boundary:fail": "node scripts/service-boundary-gate.js --mode fail",
    "error:boundary": "node scripts/raw-error-boundary-gate.js --mode report",
    "error:boundary:fail": "node scripts/raw-error-boundary-gate.js --mode fail",
    "demo:trust": "node scripts/demo-report-trust-gate.js --mode report",
    "demo:trust:fail": "node scripts/demo-report-trust-gate.js --mode fail",
    "inventory:boundary": "node scripts/inventory-boundary-gate.js --mode report",
    "inventory:boundary:fail": "node scripts/inventory-boundary-gate.js --mode fail",
    "policy:gates": "npm run inventory:boundary:fail && npm run service:boundary:ratchet && npm run error:boundary:fail && npm run demo:trust:fail",
    "verify:repo": "npm run prisma:validate && npm run typecheck && npm run policy:gates && npm run build:linted && npm test -- --runInBand",
    "verify:release": "npm run verify:repo",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "postinstall": "npx prisma generate",
    "seed": "npx prisma db seed",
    "reset": "npx prisma migrate reset && npm run seed"
  },
